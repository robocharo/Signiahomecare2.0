# Signia Home Care — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Flask secret key (generate a strong random string for production)
SECRET_KEY=change-me-to-a-strong-random-secret

# Set to "production" in production, "development" locally
FLASK_ENV=development

# Email settings (for future contact/referral form email delivery)
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# MAIL_DEFAULT_SENDER=info@signiahomecare.com
# MAIL_RECIPIENT=info@signiahomecare.com
